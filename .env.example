# TraceAI Environment Configurations Example
# Copy this file to .env and fill in your keys.

# The deployed Sui Move Package ID on Sui Testnet
VITE_SUI_PACKAGE_ID=0xe83ee2ad95984f94e2f062fc73796282c81895c49606d35a4f8f8ab55118b70b

# OpenRouter AI API Key (Get yours from https://openrouter.ai)
VITE_OPENROUTER_API_KEY=

# OpenRouter AI Model Identifier (default is openrouter/free)
VITE_OPENROUTER_MODEL=openrouter/free
